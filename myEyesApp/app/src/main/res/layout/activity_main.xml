<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Header title -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MY EYES"
        android:textColor="#00FFAA"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:fontFamily="sans-serif-condensed"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI VISION SYSTEM ACTIVE"
        android:textColor="#888888"
        android:textSize="10sp"
        android:letterSpacing="0.4"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Video + Camera Preview + Overlay -->
    <FrameLayout
        android:id="@+id/frameContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="#151515"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Shows ESP32 stream frames -->
        <ImageView
            android:id="@+id/ivVideoFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <!-- CameraX live preview (hidden when not in camera mode) -->
        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Detection overlay -->
        <com.antieyes.detector.OverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
            
        <!-- Futuristic camera corner brackets (top-left) -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_margin="16dp"
            android:layout_gravity="top|start"
            android:background="#00FFAA" />
        <View
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:layout_gravity="top|start"
            android:background="#00FFAA" />

        <!-- Futuristic camera corner brackets (bottom-right) -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_margin="16dp"
            android:layout_gravity="bottom|end"
            android:background="#00FFAA" />
        <View
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:layout_gravity="bottom|end"
            android:background="#00FFAA" />
    </FrameLayout>

    <!-- Source selector & controls -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/etStreamUrl"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="ESP32 STREAM URL"
            android:text="http://192.168.4.1/stream"
            android:inputType="textUri"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="12sp"
            android:singleLine="true"
            android:fontFamily="monospace"
            android:backgroundTint="#00FFAA"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:gravity="center">

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="ESP32"
                android:textColor="#0A0A0A"
                android:textStyle="bold"
                android:backgroundTint="#00FFAA"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="PHONE"
                android:textColor="#00FFAA"
                android:textStyle="bold"
                app:strokeColor="#00FFAA"
                app:strokeWidth="2dp"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="STOP"
                android:textColor="#FF4444"
                android:textStyle="bold"
                app:strokeColor="#FF4444"
                app:strokeWidth="2dp"
                style="?attr/materialButtonOutlinedStyle"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
